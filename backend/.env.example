# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcp_token_board

# JWT
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=24h

# Blockchain (Sepolia)
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
DISTRIBUTOR_ADDRESS=0x...

# MCP Operator Wallet (mock - replace with Fireblocks/Lit Protocol in prod)
MCP_PRIVATE_KEY=0x...

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
